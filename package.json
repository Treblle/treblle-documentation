{
    "name": "treblle-documentation",
    "version": "0.0.1",
    "private": true,
    "scripts": {                                                       
        "build": "next build --webpack",
        "postbuild": "pagefind --site .next/server/app --output-path public/_pagefind",
        "commit": "cz",
        "dev": "rm -rf .next && next dev --webpack",
        "format:check": "prettier . --check",
        "format:fix": "prettier . --write",
        "lint": "next lint",
        "prepare": "panda codegen",
        "start": "next start",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@ark-ui/react": "^5.34.1",
        "@statsig/react-bindings": "^3.32.1",
        "@statsig/web-analytics": "^3.32.1",
        "cheerio": "^1.2.0",
        "jsdom": "^29.0.0",
        "lucide-react": "^0.577.0",
        "next": "^16.0.7",
        "nextra": "4.6.1",
        "nextra-theme-docs": "4.6.1",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "turndown": "^7.2.2"
    },
    "devDependencies": {
        "@next/eslint-plugin-next": "^16.0.7",
        "@pandacss/dev": "^1.9.0",
        "@types/jsdom": "^28.0.0",
        "@types/node": "20.17.14",
        "@types/react": "^19.2.14",
        "@types/turndown": "^5.0.6",
        "eslint": "^10.0.3",
        "pagefind": "^1.4.0",
        "prettier": "^3.8.1",
        "prettier-plugin-packagejson": "^3.0.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.1"
    },
    "packageManager": "pnpm@9.5.0",
    "pnpm": {
        "overrides": {
            "lodash-es": "4.17.23"
        }
    }
}
